{
  "manifest_version": 3,
  "name": "Groundhog Day Helper",
  "version": "1.1",
  "description": "Assistant controls for Groundhog Day Town",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://dev-advocacy-magic.outsystems.app/GroundhogDay/Town*"
      ],
      "css": [
        "overlay.css"
      ],
      "js": [
        "content.js"
      ],
      "world": "MAIN"
    }
  ]
}